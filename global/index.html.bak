<script>
const nav=document.getElementById('nav');window.addEventListener('scroll',()=>nav.classList.toggle('sc',scrollY>20));
function toggleMenu(){document.getElementById('mmenu').classList.toggle('open')}
document.addEventListener('click',e=>{const m=document.getElementById('mmenu'),b=document.getElementById('hamBtn');if(m&&b&&!m.contains(e.target)&&!b.contains(e.target))m.classList.remove('open');});
if(typeof lucide!=='undefined')lucide.createIcons();
if(typeof gsap!=='undefined'){
  gsap.registerPlugin(ScrollTrigger);
  gsap.set(['.hero-tag','h1.htitle','.hsub','.hbtns .btn'],{autoAlpha:0});
  gsap.timeline({defaults:{ease:'power3.out'}})
    .fromTo('.hero-tag',{autoAlpha:0,y:-18},{autoAlpha:1,y:0,duration:.5,ease:'back.out(2)'},0)
    .fromTo('h1.htitle',{autoAlpha:0,y:32},{autoAlpha:1,y:0,duration:.7},'.2')
    .fromTo('.hsub',{autoAlpha:0,y:22},{autoAlpha:1,y:0,duration:.55},'.45')
    .fromTo('.hbtns .btn',{autoAlpha:0,y:18},{autoAlpha:1,y:0,stagger:.1,duration:.45,ease:'back.out(1.5)'},'.7');
  gsap.fromTo('.svc4-card',{opacity:0,y:28},{opacity:1,y:0,duration:.45,stagger:.08,ease:'back.out(1.5)',scrollTrigger:{trigger:'.svc4',start:'top 85%',once:true}});
  gsap.fromTo('.ipchar-img',{opacity:0,x:-36},{opacity:1,x:0,duration:.7,ease:'power2.out',scrollTrigger:{trigger:'.ipchar-grid',start:'top 82%',once:true}});
  gsap.fromTo('.ipchar-content',{opacity:0,x:28},{opacity:1,x:0,duration:.7,ease:'power2.out',scrollTrigger:{trigger:'.ipchar-grid',start:'top 82%',once:true}});
  gsap.fromTo('.srv-card',{opacity:0,y:18},{opacity:1,y:0,duration:.4,stagger:.08,ease:'power2.out',scrollTrigger:{trigger:'.srv-cards',start:'top 88%',once:true}});
  gsap.fromTo('.vision-grid',{opacity:0,y:32},{opacity:1,y:0,duration:.7,ease:'power2.out',scrollTrigger:{trigger:'.vision-grid',start:'top 82%',once:true}});
  gsap.fromTo('.bp-card',{opacity:0,scale:.88,y:24},{opacity:1,scale:1,y:0,duration:.45,stagger:.1,ease:'back.out(1.5)',scrollTrigger:{trigger:'.bp-grid',start:'top 82%',once:true}});
  gsap.fromTo('.mkt-card',{opacity:0,y:20},{opacity:1,y:0,duration:.4,stagger:.06,ease:'power2.out',scrollTrigger:{trigger:'.market-grid',start:'top 84%',once:true}});
}
</script>
