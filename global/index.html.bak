<!-- HERO -->
<section class="hero">
  <div class="hero-deco"></div>
  <div class="hero-in">
    <div class="hero-tag">
      電商倉儲<span class="hero-tag-sep">｜</span>代包代發<span class="hero-tag-sep">｜</span>空運 / 海運 / 快遞<span class="hero-tag-sep">｜</span>報關文件代辦<span class="hero-tag-sep">｜</span>WMS 庫存同步
    </div>
    <h1 class="htitle"><span class="hl2">跨境物流 + 3PL 三方倉儲</span><br>把品牌<span class="hl">「咻！」進全世界</span></h1>
    <p class="hsub">咻咻打包不只是物流，是你的「跨境戰略後勤」。從台南倉庫入庫 → WMS 同步 → 代包代發 → 出口報關 → 國際運輸 → 目的國派送，讓複雜供應鏈變得像叫外送一樣簡單。</p>
    <div class="hbtns">
      <a href="https://lin.ee/L9HtuyF" target="_blank" class="btn btn-lg"><i data-lucide="message-circle"></i>LINE 諮詢海外出貨</a>
      <a href="/international/" class="btn btn-gh"><i data-lucide="globe"></i>查看國際貿易服務</a>
    </div>
  </div>
</section>

<div class="mqbar"><div class="mqtrack">
  <div class="mqi"><span class="mq-star">★</span>跨境物流<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>3PL 三方倉儲<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>代包代發<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>出口報關<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>東南亞布局<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>WMS 庫存同步<span class="mq-sep">◆</span></div>
  <div class="mqi"><span class="mq-star">★</span>跨境物流<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>3PL 三方倉儲<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>代包代發<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>出口報關<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>東南亞布局<span class="mq-sep">◆</span></div><div class="mqi"><span class="mq-star">★</span>WMS 庫存同步<span class="mq-sep">◆</span></div>
</div></div>

<!-- 4 大服務快覽 -->
<section class="sec sbg-cr" style="padding:56px 20px">
  <div class="sec-in">
    <div class="svc4">
      <div class="svc4-card">
        <div class="svc4-icon"><i data-lucide="warehouse"></i></div>
        <div class="svc4-title">3PL 三方倉儲</div>
        <div class="svc4-desc">台南主倉，入庫盤點、效期管理、WMS 庫存即時同步</div>
      </div>
      <div class="svc4-card">
        <div class="svc4-icon"><i data-lucide="package-2"></i></div>
        <div class="svc4-title">代包代發</div>
        <div class="svc4-desc">揀貨、包裝、貼標、出貨，電商出貨全程代辦</div>
      </div>
      <div class="svc4-card">
        <div class="svc4-icon"><i data-lucide="plane"></i></div>
        <div class="svc4-title">跨境運輸</div>
        <div class="svc4-desc">空運 / 海運 / 快遞，覆蓋 20+ 國家地區，彈性搭配</div>
      </div>
      <div class="svc4-card">
        <div class="svc4-icon"><i data-lucide="file-text"></i></div>
        <div class="svc4-title">報關文件</div>
        <div class="svc4-desc">Invoice、Packing List 預審，出口合規一次搞定</div>
      </div>
    </div>
  </div>
</section>

<!-- 行政喵喵 IP Section -->
<section class="sec sbg-w">
  <div class="sec-in">
    <div class="ipchar-grid">
      <div class="ipchar-img">
        <img src="../../影片素材/角色去背/行政喵喵.png" alt="行政喵喵">
      </div>
      <div class="ipchar-content">
        <div class="slbl">全球服務</div>
        <h2>拓展全球，<br><span>行政喵喵</span>為你開路</h2>
        <p>咻咻打包不只是物流，是你的「跨境戰略後勤」。從台南倉庫入庫 → WMS 同步 → 代包代發 → 出口報關 → 國際運輸 → 目的國派送，讓複雜供應鏈變得像叫外送一樣簡單。</p>
        <div class="srv-cards">
          <div class="srv-card">
            <div class="srv-card-title">3PL 三方倉儲</div>
            <div class="srv-card-desc">台南倉庫入庫、盤點、效期 / 批號、庫位管理，WMS 即時同步</div>
          </div>
          <div class="srv-card">
            <div class="srv-card-title">代包代發 電商出貨</div>
            <div class="srv-card-desc">揀貨、包裝、貼單、出貨，支援蝦皮 / MOMO / 自有品牌</div>
          </div>
          <div class="srv-card">
            <div class="srv-card-title">跨境空海運</div>
            <div class="srv-card-desc">空運要快、海運要省、快遞要彈性，依需求彈性搭配</div>
          </div>
          <div class="srv-card">
            <div class="srv-card-title">報關文件 國貿秘書</div>
            <div class="srv-card-desc">Invoice / Packing List 預審，出口合規，省心省力</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 品牌願景與里程碑 -->
<section class="sec sbg-cr">
  <div class="sec-in">
    <div class="vision-grid">
      <div>
        <div class="slbl">全球願景</div>
        <h2 style="font-size:clamp(24px,3vw,38px);font-weight:900;color:var(--br);margin-bottom:16px;line-height:1.3">台灣物流走出去<br><span style="color:var(--og)">讓好物觸及全球</span></h2>
        <p style="font-size:15px;color:var(--brm);line-height:1.8;margin-bottom:14px">咻咻打包的全球發展藍圖，是以台灣為出發點，逐步在東南亞建立倉儲據點，讓台灣品牌能以在地速度服務海外顧客。</p>
        <p style="font-size:15px;color:var(--brm);line-height:1.8;margin-bottom:14px">目前我們已透過空運、海運合作夥伴為台灣品牌提供出口服務，覆蓋 20+ 國家地區。下一步是在東南亞建立第一個海外倉庫，2027 年完成布局。</p>
