<script>
const nav=document.getElementById('nav');window.addEventListener('scroll',()=>nav.classList.toggle('sc',scrollY>20));
function toggleMenu(){document.getElementById('mmenu').classList.toggle('open')}
document.addEventListener('click',e=>{const m=document.getElementById('mmenu'),b=document.getElementById('hamBtn');if(m&&b&&!m.contains(e.target)&&!b.contains(e.target))m.classList.remove('open');});
function toggleFaq(item){const was=item.classList.contains('open');document.querySelectorAll('.fqi').forEach(i=>i.classList.remove('open'));if(!was)item.classList.add('open');}
if(typeof lucide!=='undefined')lucide.createIcons();
if(typeof gsap!=='undefined'){
  gsap.registerPlugin(ScrollTrigger);
  gsap.set(['h1.htitle','.hsub','.hbtns .btn','.hti','.char-wrap','.badge-live'],{autoAlpha:0});
  gsap.timeline({defaults:{ease:'power3.out'}})
    .fromTo('.badge-live',{autoAlpha:0,y:-18},{autoAlpha:1,y:0,duration:.5,ease:'back.out(2)'},0)
    .fromTo('h1.htitle',{autoAlpha:0,y:32},{autoAlpha:1,y:0,duration:.7},'.2')
    .fromTo('.hsub',{autoAlpha:0,y:22},{autoAlpha:1,y:0,duration:.55},'.45')
    .fromTo('.hbtns .btn',{autoAlpha:0,y:18},{autoAlpha:1,y:0,stagger:.1,duration:.45,ease:'back.out(1.5)'},'.7')
    .fromTo('.hti',{autoAlpha:0,x:-12},{autoAlpha:1,x:0,stagger:.07,duration:.4},'1')
    .fromTo('.char-wrap',{autoAlpha:0,x:48},{autoAlpha:1,x:0,duration:1,ease:'power2.out'},'.15');
  gsap.fromTo('.secretary-img',{opacity:0,x:-36},{opacity:1,x:0,duration:.7,ease:'power2.out',scrollTrigger:{trigger:'.secretary-grid',start:'top 82%',once:true}});
  gsap.fromTo('.secretary-content',{opacity:0,x:28},{opacity:1,x:0,duration:.7,ease:'power2.out',scrollTrigger:{trigger:'.secretary-grid',start:'top 82%',once:true}});
  gsap.fromTo('.sec-pt',{opacity:0,y:16},{opacity:1,y:0,duration:.4,stagger:.1,ease:'power2.out',scrollTrigger:{trigger:'.sec-pts',start:'top 88%',once:true}});
  gsap.fromTo('.svc-card',{opacity:0,y:40},{opacity:1,y:0,duration:.6,stagger:.1,ease:'power3.out',scrollTrigger:{trigger:'.service-grid',start:'top 82%',once:true}});
  gsap.fromTo('.cmp-card',{opacity:0,y:32},{opacity:1,y:0,duration:.6,stagger:.15,ease:'power2.out',scrollTrigger:{trigger:'.compare-grid',start:'top 82%',once:true}});
  gsap.fromTo('.pain-card',{opacity:0,x:-24},{opacity:1,x:0,duration:.5,stagger:.1,ease:'power2.out',scrollTrigger:{trigger:'.pain-grid',start:'top 84%',once:true}});
  gsap.fromTo('.region-card',{opacity:0,scale:.88},{opacity:1,scale:1,duration:.4,stagger:.07,ease:'back.out(1.5)',scrollTrigger:{trigger:'.region-grid',start:'top 82%',once:true}});
  gsap.fromTo('.fqi',{opacity:0,y:16},{opacity:1,y:0,duration:.4,stagger:.06,ease:'power2.out',scrollTrigger:{trigger:'.faq-list',start:'top 84%',once:true}});
}
</script>
