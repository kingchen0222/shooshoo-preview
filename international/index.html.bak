<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>國際貿易代理・空海運報關服務｜台灣進出口貨物・咻咻打包</title>
<meta name="description" content="咻咻打包提供台灣進出口國際貿易代理服務，空運、海運、快遞報關一手包辦。HS CODE 建議、貿易文件代辦、東南亞與歐美航線配送，讓你的商品順利走向全世界。">
<meta property="og:title" content="國際貿易代理・空海運報關｜咻咻打包進出口服務">
<meta property="og:url" content="https://www.shooshoo.com.tw/international/">
<link rel="canonical" href="https://www.shooshoo.com.tw/international/">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
<style>
:root{--cr:#FFF8ED;--crl:#FFFCF5;--crd:#FFE9C8;--og:#FF6B35;--ogd:#E85520;--yw:#FFC845;--br:#2D1B0E;--brm:#5C3D1E;--brl:#9B7250;--gy:#6B7280;--gn:#2ECC71;--lg:#06C755;--s1:0 2px 8px rgba(45,27,14,.08);--s2:0 6px 24px rgba(45,27,14,.12);--s3:0 12px 48px rgba(45,27,14,.16);--r1:12px;--r2:20px;--rf:9999px}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}body{font-family:'Noto Sans TC',-apple-system,sans-serif;background:var(--crl);color:var(--br);overflow-x:hidden}a{text-decoration:none;color:inherit}img{display:block;max-width:100%}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}@keyframes pulse{0%{transform:scale(1);opacity:.6}100%{transform:scale(1.8);opacity:0}}@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(255,252,245,.93);backdrop-filter:blur(16px);border-bottom:1px solid rgba(45,27,14,.06)}.nav-in{max-width:1200px;margin:0 auto;padding:0 20px;height:72px;display:flex;align-items:center;justify-content:space-between;gap:8px}.logo{display:flex;align-items:center;gap:12px;flex-shrink:0}.logo img{width:48px;height:48px;object-fit:contain}.logo-name{font-size:20px;font-weight:900;color:var(--og)}.logo-en{font-size:11px;color:var(--brl)}.nav-links{display:flex;align-items:center;gap:2px;list-style:none}.nav-links a{padding:7px 12px;border-radius:var(--r1);font-size:15px;font-weight:600;color:var(--brm);transition:all .2s;white-space:nowrap}.nav-links a:hover{color:var(--og)}.nav-links .has-drop{position:relative}.nav-links .has-drop:hover .dropdown{display:block}.dropdown{display:none;position:absolute;top:calc(100% + 8px);left:0;background:#fff;border:1px solid rgba(45,27,14,.08);border-radius:var(--r2);padding:8px;min-width:200px;box-shadow:var(--s3);z-index:10}.dropdown a{display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:var(--r1);font-size:13px;color:var(--brm);transition:all .2s}.dropdown a:hover{background:var(--cr);color:var(--og)}.nav-cta{background:var(--og)!important;color:#fff!important;border-radius:var(--rf)!important;padding:8px 18px!important;font-weight:800!important}.ham{display:none;flex-direction:column;gap:5px;padding:8px;background:var(--crd);border-radius:8px;border:none;cursor:pointer}.ham span{display:block;width:20px;height:2px;background:var(--br);border-radius:3px}.mmenu{display:none;position:fixed;top:72px;left:0;right:0;z-index:199;background:rgba(255,252,245,.97);backdrop-filter:blur(16px);border-bottom:1px solid var(--crd);padding:12px 20px 20px;flex-direction:column;gap:3px}.mmenu.open{display:flex}.mmenu a{padding:11px 14px;border-radius:var(--r1);font-size:15px;font-weight:600;color:var(--brm)}.mmenu .mc{background:var(--og);color:#fff!important;text-align:center;border-radius:var(--rf)!important;margin-top:6px;font-weight:800!important}
.hero{min-height:80vh;padding:100px 20px 80px;background:linear-gradient(135deg,#1A0F05 0%,#2D1B0E 50%,#1A3A2A 100%);display:flex;align-items:center;position:relative;overflow:hidden}.hero::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,200,69,.06) 1px,transparent 1px);background-size:36px 36px}.hero-in{max-width:1200px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;position:relative;z-index:1}.badge-live{display:inline-flex;align-items:center;gap:8px;background:rgba(255,200,69,.15);border:1.5px solid rgba(255,200,69,.4);border-radius:var(--rf);padding:6px 14px;font-size:12px;font-weight:700;color:var(--yw);margin-bottom:18px}h1.htitle{font-size:clamp(30px,4.2vw,54px);font-weight:900;line-height:1.18;color:#fff;margin-bottom:16px}.htitle .hl{color:var(--yw)}.htitle .hl2{color:var(--og)}.hsub{font-size:15px;color:rgba(255,248,237,.75);line-height:1.75;margin-bottom:22px;text-wrap:pretty}.hbtns{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:26px}.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 26px;border-radius:var(--rf);font-size:15px;font-weight:800;border:none;cursor:pointer;transition:all .25s cubic-bezier(.34,1.56,.64,1)}.btn-lg{background:var(--lg);color:#fff}.btn-lg:hover{transform:translateY(-3px)}.btn-og{background:var(--og);color:#fff}.btn-og:hover{transform:translateY(-3px)}.btn-gh{background:rgba(255,255,255,.1);color:#fff;border:1.5px solid rgba(255,255,255,.3)}.btn-gh:hover{transform:translateY(-3px)}.htrust{display:flex;flex-wrap:wrap;gap:16px}.hti{display:flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:rgba(255,248,237,.75)}.hti [data-lucide]{width:14px;height:14px;color:var(--yw);stroke-width:2}
.char-wrap{display:flex;align-items:center;justify-content:center;height:340px}.char-wrap img{height:300px;width:auto;filter:drop-shadow(0 20px 40px rgba(0,0,0,.3));animation:float 4s ease-in-out infinite}
.mqbar{background:var(--br);padding:12px 0;overflow:hidden}.mqtrack{display:flex;width:max-content;animation:marquee 28s linear infinite}.mqi{display:flex;align-items:center;gap:9px;padding:0 28px;color:#fff;font-size:13px;font-weight:700;white-space:nowrap}.mq-star{color:var(--yw)}.mq-sep{color:var(--yw);opacity:.4;font-size:9px}
.sec{padding:80px 20px}.sec-in{max-width:1200px;margin:0 auto}.sec-hd{text-align:center;margin-bottom:52px}.slbl{display:inline-flex;border-left:3px solid var(--og);padding:3px 0 3px 12px;font-size:11px;font-weight:800;color:var(--og);letter-spacing:.1em;text-transform:uppercase;margin-bottom:18px}h2.stitle{font-size:clamp(24px,3.2vw,40px);font-weight:900;color:var(--br);line-height:1.25;margin-bottom:12px}.stitle .oc{color:var(--og)}.sdesc{font-size:16px;color:var(--brm);max-width:560px;margin:0 auto;line-height:1.7}
.sbg-w{background:#fff;padding:80px 20px}.sbg-cr{background:var(--cr)}.sbg-dk{background:linear-gradient(135deg,#2D1B0E 0%,#3D2010 60%,#1A0F05 100%);padding:80px 20px}.sbg-dk .stitle{color:#fff}.sbg-dk .slbl{border-left-color:var(--yw);color:var(--yw)}.sbg-dk .sdesc{color:rgba(255,248,237,.65)}
/* 國貿秘書 section */
.secretary-grid{display:grid;grid-template-columns:1fr 1.6fr;gap:60px;align-items:center}.secretary-img{text-align:center}.secretary-img img{max-height:380px;object-fit:contain;filter:drop-shadow(0 20px 48px rgba(45,27,14,.18));animation:float 4s ease-in-out infinite}.secretary-content .slbl{margin-bottom:14px}.secretary-content h2{font-size:clamp(22px,2.8vw,36px);font-weight:900;color:var(--br);margin-bottom:12px;line-height:1.3}.secretary-content h2 span{color:var(--og)}.secretary-content p{font-size:15px;color:var(--brm);line-height:1.8;margin-bottom:24px}.sec-pts{display:flex;flex-direction:column;gap:12px}.sec-pt{display:flex;align-items:flex-start;gap:12px;background:var(--cr);border-radius:var(--r1);padding:14px 16px}.sec-pt-icon{width:36px;height:36px;border-radius:10px;background:rgba(255,107,53,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0}.sec-pt-icon [data-lucide]{width:18px;height:18px;color:var(--og)}.sec-pt-text strong{display:block;font-size:13px;font-weight:900;color:var(--br);margin-bottom:2px}.sec-pt-text span{font-size:12px;color:var(--gy);line-height:1.5}
/* 流程條 */
.flow-bar{background:linear-gradient(135deg,#2D1B0E,#3D2010);padding:36px 20px}.flow-in{max-width:1200px;margin:0 auto}.flow-steps{display:flex;align-items:center;justify-content:center;gap:0;overflow-x:auto}.flow-step{display:flex;align-items:center;gap:0;flex-shrink:0}.flow-node{display:flex;flex-direction:column;align-items:center;gap:8px;padding:0 20px}.flow-num{width:40px;height:40px;border-radius:50%;background:rgba(255,200,69,.2);border:2px solid rgba(255,200,69,.5);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:var(--yw)}.flow-label{font-size:13px;font-weight:800;color:#fff;white-space:nowrap}.flow-arrow{font-size:18px;color:rgba(255,200,69,.5);padding:0 4px}
/* 服務卡片 */
.service-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}.svc-card{background:#fff;border:1px solid rgba(45,27,14,.07);border-radius:var(--r2);padding:24px;box-shadow:0 2px 12px rgba(45,27,14,.05);transition:all .3s;position:relative;overflow:hidden}.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--og),var(--yw))}.svc-card:hover{transform:translateY(-6px);box-shadow:var(--s3)}.svc-icon{width:48px;height:48px;border-radius:12px;background:rgba(255,107,53,.08);display:flex;align-items:center;justify-content:center;color:var(--og);margin-bottom:14px}.svc-icon [data-lucide]{width:22px;height:22px;stroke-width:1.7}.svc-h{font-size:15px;font-weight:900;color:var(--br);margin-bottom:7px}.svc-p{font-size:13px;color:var(--gy);line-height:1.65}
/* 空運 vs 海運 對比 */
.compare-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}.cmp-card{border-radius:var(--r2);padding:32px 28px;position:relative;overflow:hidden}.cmp-air{background:linear-gradient(135deg,#1A2D40,#0A1A2A);border:1.5px solid rgba(255,200,69,.2)}.cmp-sea{background:linear-gradient(135deg,#1A2D0E,#0A2010);border:1.5px solid rgba(46,204,113,.2)}.cmp-icon{font-size:48px;margin-bottom:16px}.cmp-title{font-size:22px;font-weight:900;color:#fff;margin-bottom:4px}.cmp-sub{font-size:12px;font-weight:800;color:var(--yw);letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px}.cmp-desc{font-size:14px;color:rgba(255,248,237,.7);line-height:1.7;margin-bottom:20px}.cmp-tags{display:flex;flex-wrap:wrap;gap:8px}.cmp-tag{background:rgba(255,255,255,.08);border-radius:var(--rf);padding:5px 12px;font-size:12px;font-weight:700;color:rgba(255,248,237,.8)}
/* 痛點 */
.pain-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}.pain-card{background:#fff;border-radius:var(--r2);padding:24px;border-left:4px solid var(--og);box-shadow:var(--s1);transition:all .3s}.pain-card:hover{transform:translateX(6px);box-shadow:var(--s2)}.pain-h{display:flex;align-items:center;gap:10px;margin-bottom:10px}.pain-icon{width:34px;height:34px;border-radius:10px;background:rgba(255,107,53,.08);display:flex;align-items:center;justify-content:center}.pain-icon [data-lucide]{width:16px;height:16px;color:var(--og)}.pain-title{font-size:14px;font-weight:900;color:var(--br)}.pain-desc{font-size:13px;color:var(--gy);line-height:1.65}
.region-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}.region-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:var(--r2);padding:22px;text-align:center;transition:all .3s;cursor:pointer}.region-card:hover{background:rgba(255,255,255,.12);border-color:rgba(255,200,69,.3);transform:translateY(-4px)}.region-flag{font-size:36px;margin-bottom:10px}.region-name{font-size:15px;font-weight:800;color:#fff;margin-bottom:6px}.region-desc{font-size:12px;color:rgba(255,248,237,.5);line-height:1.5}
.faq-list{max-width:780px;margin:0 auto;display:flex;flex-direction:column;gap:10px}.fqi{background:#fff;border-radius:var(--r2);border:1px solid rgba(45,27,14,.07);overflow:hidden;transition:border-color .3s}.fqi.open{border-color:rgba(255,107,53,.3)}.fqq{display:flex;align-items:center;justify-content:space-between;padding:17px 20px;cursor:pointer;gap:12px}.fqq-inner{display:flex;align-items:center;gap:10px}.fqicon{width:28px;height:28px;border-radius:8px;background:rgba(255,107,53,.08);display:flex;align-items:center;justify-content:center}.fqicon [data-lucide]{width:14px;height:14px;color:var(--og)}.fqtext{font-size:15px;font-weight:700;color:var(--br)}.fqtog{width:26px;height:26px;border-radius:8px;background:var(--cr);display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--og);font-weight:900;transition:all .3s}.fqi.open .fqtog{background:var(--og);color:#fff;transform:rotate(45deg)}.fqa{max-height:0;overflow:hidden;transition:max-height .4s ease}.fqa-in{padding:0 20px 16px 58px;font-size:14px;color:var(--gy);line-height:1.75}
.cta-sec{background:linear-gradient(135deg,#2D1B0E 0%,#3D2010 100%);padding:80px 20px;text-align:center}.cta-sec h2{font-size:clamp(26px,3.5vw,44px);font-weight:900;color:#fff;margin-bottom:14px}.cta-sec p{font-size:16px;color:rgba(255,248,237,.75);margin-bottom:36px}.cta-btns{display:flex;flex-wrap:wrap;gap:14px;justify-content:center}
footer{background:var(--br);padding:48px 20px 20px}.foot-in{max-width:1200px;margin:0 auto}.foot-top{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;margin-bottom:36px}.foot-logo{display:flex;align-items:center;gap:10px;margin-bottom:14px}.foot-logo img{width:40px;height:40px;object-fit:contain}.foot-bname{font-size:17px;font-weight:900;color:var(--og)}.foot-desc{font-size:13px;line-height:1.7;color:rgba(255,248,237,.6);margin-bottom:16px}.fsoc{display:flex;gap:10px}.fsoc a{width:34px;height:34px;border-radius:9px;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;transition:all .2s;color:rgba(255,248,237,.7)}.fsoc a:hover{background:var(--og);color:#fff}.fsoc [data-lucide]{width:16px;height:16px}.foot-ct{font-size:13px;font-weight:800;color:var(--og);text-transform:uppercase;letter-spacing:.06em;margin-bottom:14px}.foot-lks{list-style:none;display:flex;flex-direction:column;gap:8px}.foot-lks a{font-size:13px;color:rgba(255,248,237,.65);transition:color .2s}.foot-lks a:hover{color:var(--og)}.foot-bot{border-top:1px solid rgba(255,255,255,.08);padding-top:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}.foot-copy{font-size:12px;color:rgba(255,248,237,.4)}.foot-copy span{color:rgba(255,248,237,.6)}
.float-cta{position:fixed;right:20px;bottom:24px;display:flex;flex-direction:column;gap:10px;z-index:100}.fb{display:flex;align-items:center;gap:8px;padding:12px 18px;border-radius:var(--rf);font-size:14px;font-weight:800;color:#fff;box-shadow:var(--s3);transition:all .25s;position:relative}.fb-ln{background:var(--lg)}.fb-ph{background:var(--og)}.fb-pulse{position:absolute;top:-4px;right:-4px;width:12px;height:12px;border-radius:50%;background:var(--yw);border:2px solid #fff;animation:pulse 2s ease-out infinite}.fb [data-lucide]{width:16px;height:16px}.mob-bar{display:none;position:fixed;bottom:0;left:0;right:0;z-index:100;background:#fff;border-top:1px solid var(--crd);padding:10px 16px 14px}.mob-row{display:flex;gap:10px}.mb-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:8px;padding:13px;border-radius:var(--rf);font-size:14px;font-weight:800;color:#fff}.mb-ln{background:var(--lg)}.mb-ev{background:var(--og)}.mb-btn [data-lucide]{width:16px;height:16px}
@media(max-width:1024px){.hero-in{grid-template-columns:1fr;text-align:center}.hbtns,.htrust{justify-content:center}.secretary-grid{grid-template-columns:1fr;gap:32px}.secretary-img img{max-height:260px}.service-grid{grid-template-columns:1fr 1fr}.compare-grid{grid-template-columns:1fr}.pain-grid{grid-template-columns:1fr}.region-grid{grid-template-columns:1fr 1fr}.foot-top{grid-template-columns:1fr 1fr}}
@media(max-width:768px){.nav-links{display:none}.ham{display:flex}.float-cta{display:none}.mob-bar{display:block}.service-grid{grid-template-columns:1fr 1fr}.flow-steps{gap:0}.foot-top{grid-template-columns:1fr}}
@media(max-width:500px){.service-grid{grid-template-columns:1fr}.region-grid{grid-template-columns:1fr 1fr}}
</style>
</head>
